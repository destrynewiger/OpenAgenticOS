# OpenAgenticOS — copy to .env and fill only what you want to connect.
# Nothing here is required to run the local dashboard. No external pushes happen
# by default.

# --- Optional account/contact research provider ---
SUMBLE_API_KEY=
SUMBLE_EMAIL=
SUMBLE_PASSWORD=

# --- Common Room (community/product/activity signals) ---
COMMON_ROOM_API_KEY=

# --- Apollo / sequencing export examples ---
APOLLO_API_KEY=

# --- Amplemarket (sequencing + account/contact enrichment) ---
AMPLEMARKET_API_KEY=

# --- Research / LLM providers (optional; templates used when absent) ---
OPENAI_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=

# --- Agent OS Council / N2 via OpenRouter or LiteLLM (optional) ---
# Enables the live multi-lens council instead of local fallback templates.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
N2_MODEL=nex-agi/nex-n2-pro:free
# Alternative OpenAI-compatible router:
LITELLM_BASE_URL=
LITELLM_API_KEY=
# Gemini can also use Google Application Default Credentials (ADC), which is
# required when your Google org disallows API keys. Run the setup command from
# Settings or a terminal, then set your Google Cloud project here.
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
# Model used for LLM-enhanced call notes / research briefs when a key is present.
LLM_MODEL=gpt-4.1-mini
# For Google ADC-only Gemini, use: LLM_MODEL=gemini-2.5-flash

# --- Storage ---
# sqlite path or sqlite: URL. Defaults to ./data/gtm.db
DATABASE_URL=sqlite:./data/gtm.db

# --- Feature flags (all OFF by default = safe, local-only) ---
# Allow adapters to actually hit the network (status pages, web research).
ENABLE_BROWSER_RESEARCH=false
# Allow pushing contacts into Apollo (otherwise CSV export only).
ENABLE_APOLLO_PUSH=false
# Allow pushing leads into Amplemarket (otherwise CSV export only).
ENABLE_AMPLEMARKET_PUSH=false

# --- Server ---
PORT=4100
# Default is loopback only. Set HOST=0.0.0.0 to expose on LAN/tailnet, and only
# do that with OPS_TOKEN set.
HOST=127.0.0.1
# Shared secret for privileged code-exec/file-read endpoints from non-loopback
# clients. Send it as the X-Ops-Token header.
OPS_TOKEN=

# --- Seller identity (used in call-note templates) ---
SELLER_NAME=Your Name
SELLER_COMPANY=Your Company

# --- Call cockpit / Chrome extension example ---
# Extra origins allowed to call the API cross-origin. Chrome extension origins
# are allowed automatically for the cockpit; use comma-separated origins here,
# or * only for a trusted local tool.
COCKPIT_ALLOWED_ORIGINS=
# Public base URL used for the /cockpit "Brief link" written into a dial sheet.
# Local: http://localhost:4100. If hosted elsewhere, use your HTTPS URL.
COCKPIT_PUBLIC_URL=

# --- Call queue example ---
QUEUE_CONTACTS_PER_ACCOUNT=3
QUEUE_MAX=100

# --- Optional local memory folder for persona talk tracks + hard copy rules ---
# Demo data uses sample-data/brain. Set this for your own local memory folder.
BRAIN_DIR=

# --- Google Sheet dial list example ---
# Path to a Google service-account JSON (Sheets API enabled). Share the target
# sheet with the service account's client_email. Or paste the JSON inline into
# GOOGLE_SHEETS_CREDENTIALS_JSON.
GOOGLE_SHEETS_CREDENTIALS=
GOOGLE_SHEETS_CREDENTIALS_JSON=
DIAL_SHEET_ID=
DIAL_SHEET_TAB=Dial List

# --- Optional account monitor ---
# Comma-separated domains to keep watching (created as accounts if missing).
WATCHLIST_DOMAINS=
# Max accounts to (re-)research per monitor run, to bound provider credit use.
MONITOR_MAX_ACCOUNTS=25
